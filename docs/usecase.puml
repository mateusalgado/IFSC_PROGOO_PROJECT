@startuml usecase
!pragma layout smetana

skinparam backgroundColor #FFFFFF
skinparam ActorBackgroundColor #F5F5F7
skinparam ActorBorderColor #FF9F0A
skinparam ActorFontColor #1C1C1E
skinparam UsecaseBackgroundColor #F5F5F7
skinparam UsecaseBorderColor #636366
skinparam UsecaseFontColor #1C1C1E
skinparam ArrowColor #FF9F0A
skinparam PackageBorderColor #48484A
skinparam PackageFontColor #1C1C1E
skinparam NoteBackgroundColor #F5F5F7
skinparam NoteBorderColor #48484A
skinparam NoteFontColor #1C1C1E

actor "Usuário" as user

rectangle "Calculadora iPhone" {

    package "Geral" {
        usecase "Alternar modo\n(Normal ↔ Científico)" as UC00
        usecase "Inserir número\n(dígito / ponto)" as UC01
    }

    package "Modo Normal" {
        usecase "Operação binária\n(+, -, ×, ÷)" as UC02
        usecase "Calcular resultado (=)" as UC03
        usecase "Limpar (AC / CE)" as UC04
        usecase "Inverter sinal (+/-)" as UC05
        usecase "Porcentagem (%)" as UC06
        usecase "Memória\n(mc, m+, m-, mr)" as UC07
    }

    package "Modo Científico" {
        usecase "Trigonométrica\n(sin, cos, tan)" as UC08
        usecase "Hiperbólica\n(sinh, cosh, tanh)" as UC09
        usecase "Logaritmo\n(ln, log₁₀)" as UC10
        usecase "Potência\n(x², x³, xʸ, eˣ, 10ˣ)" as UC11
        usecase "Raiz\n(²√x, ³√x, ʸ√x)" as UC12
        usecase "Fatorial (x!)" as UC13
        usecase "Constante (π, e)" as UC14
        usecase "Notação EE" as UC15
        usecase "Rand" as UC16
        usecase "Inverso (1/x)" as UC17
        usecase "Rad/Grau" as UC18
        usecase "Funções 2nd\n(inversas)" as UC19
    }
}

user --> UC00
user --> UC01
user --> UC02
user --> UC03
user --> UC04
user --> UC05
user --> UC06
user --> UC07
user --> UC08
user --> UC09
user --> UC10
user --> UC11
user --> UC12
user --> UC13
user --> UC14
user --> UC15
user --> UC16
user --> UC17
user --> UC18
user --> UC19

UC02 ..> UC01 : <<include>>
UC03 ..> UC02 : <<include>>
UC08 ..> UC01 : <<include>>
UC19 ..> UC08 : <<extend>>
UC19 ..> UC09 : <<extend>>
UC19 ..> UC10 : <<extend>>
UC19 ..> UC11 : <<extend>>
UC19 ..> UC12 : <<extend>>

note right of UC00
  UC08–UC19 exigem
  modo Científico ativo
end note

@enduml
